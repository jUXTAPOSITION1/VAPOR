# ── Server ──────────────────────────────────────────────────────────────
PORT=3402
NODE_ENV=production
LOG_LEVEL=info

# ── Database ────────────────────────────────────────────────────────────
# Dev: file-based SQLite. Prod: point at a real Postgres instance.
DATABASE_URL="file:./dev.db"

# ── Settlement ──────────────────────────────────────────────────────────
# The wallet VAPOR uses to broadcast settlement transactions. This wallet
# never holds buyer/seller funds — it only pays gas for transferWithAuthorization
# calls. Fund it with a small amount of ETH on each chain you enable.
SETTLEMENT_SIGNER_PRIVATE_KEY=0x...

# Logs a warning (and drops the vapor_signer_native_balance_wei metric) once
# the signer's gas balance falls below this many ETH — an early warning
# before settlement actually starts failing for lack of gas. Default is
# comfortably above one transferWithAuthorization's cost even during a spike.
SIGNER_LOW_BALANCE_ETH=0.01

# One or more RPC URLs per chain you want VAPOR to support (comma-separated
# for automatic failover — the first is primary, the rest are only used if
# it errors; see src/blockchain/clients/chain.client.ts). Only chains with
# both an RPC URL AND a verified token contract address configured (see
# src/config/networks.ts) are advertised on GET /supported.
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# ── Reputation intelligence provider ─────────────────────────────────────
# Optional. If unset, the risk scanner still runs on-chain heuristics alone
# (wallet age, transaction count, contract-vs-EOA) — it just skips the
# external reputation signal rather than failing closed or open.
REPUTATION_PROVIDER_BASE_URL=
REPUTATION_PROVIDER_API_KEY=

# ── Policy defaults (overridable per payee — see docs/risk-scanning.md) ──
DEFAULT_MAX_RISK_SCORE=70
DEFAULT_MAX_AMOUNT_USD=1000

# ── Webhooks ────────────────────────────────────────────────────────────
WEBHOOK_SIGNING_SECRET=

# ── Auth ────────────────────────────────────────────────────────────────
# Bearer token(s) resource servers use to call VAPOR's own endpoints
# (comma-separated). Leave unset to run fully open (fine for local dev,
# not for a public deployment).
API_KEYS=

# ── Rate limiting (per IP) ────────────────────────────────────────────────
# /verify, /settle, and their batch siblings are unauthenticated by protocol
# necessity, and /risk-scan + /payee-reputation are free RPC-cost-bearing
# reads with no payment gating them at all — these defaults are sane for a
# single real agent's traffic; lower them if you're seeing abuse.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_PAYMENT=120
RATE_LIMIT_MAX_SCAN=30
