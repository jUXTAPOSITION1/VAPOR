// VAPOR's audit + analytics store. SQLite in development, Postgres in
// production — only the `provider`/`url` below change between the two,
// the schema itself is portable.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// One row per /verify or /settle call — the audit-grade record a payee
/// can export to prove exactly what was checked and decided, and when.
model PaymentRecord {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  stage    String // "verify" | "settle"
  network  String
  resource String
  payTo    String
  asset    String
  amount   String // raw token units, kept as a string to preserve precision

  payer         String?
  isValid       Boolean
  invalidReason String?

  riskScore   Int?
  riskBand    String?
  riskReasons String? // JSON-encoded string[]

  settled         Boolean?
  transactionHash String?
  errorReason     String?

  /// Chain-linkage fields (nullable so pre-existing rows from before this
  /// feature shipped stay valid without a backfill) — see
  /// src/core/audit/audit-chain.service.ts. `seq` is an app-assigned
  /// strictly-increasing integer (not the DB's own autoincrement, since
  /// SQLite only supports that on the actual primary key) giving the chain
  /// a total order independent of `id`/`createdAt` collisions. `prevHash`
  /// is the previous chained row's `recordHash` (or the fixed genesis
  /// constant for the first chained row); `recordHash` covers this row's
  /// own content plus `prevHash`, so altering OR deleting any chained row
  /// breaks verification for everything chained after it.
  seq        Int?    @unique
  prevHash   String?
  recordHash String?

  @@index([payTo, createdAt])
  @@index([payer])
  @@index([transactionHash])
}

/// Queued webhook delivery. Created only once a dispatch's first attempt
/// fails (a successful first attempt is never persisted — no DB write on
/// the fast/common path), then retried with exponential backoff by
/// retryDueWebhooks() until it succeeds or MAX_ATTEMPTS is reached. Rows
/// are never deleted — "delivered"/"failed" terminal rows double as an
/// audit trail of every retry a payee's endpoint ever needed.
model WebhookDelivery {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  url       String
  eventType String
  payload   String // raw JSON body sent (and signed) verbatim on every attempt
  signature String?

  status        String // "pending" | "delivered" | "failed"
  attempts      Int
  nextAttemptAt DateTime
  lastError     String?
  deliveredAt   DateTime?

  @@index([status, nextAttemptAt])
}

/// A resource server's self-declared x402 Bazaar discovery listing — VAPOR
/// acting as a Bazaar-compatible facilitator in its own right (see
/// docs/API.md's Discovery section), not dependent on any other
/// facilitator's catalog. Upserted via POST /discovery/register (API-key
/// gated, scoped to the listing's own payTo — see auth.middleware.ts),
/// read via GET /discovery/resources[/search], which any x402 Bazaar
/// client (e.g. `withBazaar()` from @x402/extensions/bazaar) can query
/// directly against VAPOR the same way it would against CDP's facilitator.
model ResourceListing {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// The route/URL this listing advertises (e.g. "https://api.example.com/data/token_intel").
  resource    String
  type        String @default("http") // "http" | "mcp" — matches the x402 Bazaar spec's DiscoveryResource.type
  x402Version Int

  /// Denormalized from `accepts` for filtering/indexing without parsing JSON
  /// on every list/search call — the source of truth is still `accepts`.
  payTo   String
  scheme  String
  network String

  accepts String // JSON-encoded PaymentRequirements[] — the real accepted payment kind(s)

  description String?
  mimeType    String?
  serviceName String?
  tags        String? // JSON-encoded string[]
  iconUrl     String?
  extensions  String? // JSON-encoded Record<string, unknown> — the declared bazaar extension payload

  /// Soft-unlist flag: a resource server re-registers with `discoverable:
  /// false` to pull a listing without needing a separate delete endpoint.
  discoverable Boolean @default(true)

  @@unique([resource, payTo])
  @@index([payTo])
  @@index([scheme, network])
  @@index([discoverable])
}
